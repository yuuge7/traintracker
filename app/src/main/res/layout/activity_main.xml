<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tvTotalKm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="@string/lbl_total_year"
                android:textColor="@color/accent_blue"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </androidx.cardview.widget.CardView>

        <CheckBox
            android:id="@+id/cbManualMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lbl_manual_mode"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:id="@+id/layoutTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_start_timer"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:id="@+id/tvCalculatedDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/msg_duration_calc"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="20dp"
                android:textColor="#D32F2F"
                android:textStyle="bold"/>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:id="@+id/layoutManualInputs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="15dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_date"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="5dp"/>

                <Button
                    android:id="@+id/btnSelectDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_select_date"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF9800"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnStartTime"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_time_start"
                        android:textColor="#333"
                        android:backgroundTint="#E0E0E0"
                        android:layout_marginEnd="5dp"/>

                    <Button
                        android:id="@+id/btnEndTime"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_time_end"
                        android:textColor="#333"
                        android:backgroundTint="#E0E0E0"
                        android:layout_marginStart="5dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvManualCalculated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/msg_duration_calc_manual"
                    android:textColor="@color/accent_blue"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lbl_from"
            android:textColor="@color/text_primary"
            android:textStyle="bold"/>

        <Spinner
            android:id="@+id/spinnerStart"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:backgroundTint="@color/text_secondary"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lbl_to"
            android:textColor="@color/text_primary"
            android:textStyle="bold"/>

        <Spinner
            android:id="@+id/spinnerEnd"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:backgroundTint="@color/text_secondary"
            android:layout_marginBottom="20dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:scrollbars="none">

            <RadioGroup
                android:id="@+id/radioGroupType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent_blue"
                    android:checked="true"
                    android:paddingEnd="10dp"/>
                <RadioButton
                    android:id="@+id/rbRE"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R-E"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent_blue"
                    android:paddingEnd="10dp"/>
                <RadioButton
                    android:id="@+id/rbIR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IR"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent_blue"
                    android:paddingEnd="10dp"/>
                <RadioButton
                    android:id="@+id/rbIC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IC"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent_blue"
                    android:paddingEnd="10dp"/>
                <RadioButton
                    android:id="@+id/rbIRN"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IRN"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent_blue"
                    android:paddingEnd="10dp"/>
            </RadioGroup>
        </HorizontalScrollView>

        <EditText
            android:id="@+id/etTrainNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="@string/hint_train_number"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/accent_blue"
            android:inputType="number"
            android:minHeight="48dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_save_trip"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1976D2"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnHistory"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/btn_history"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444444"
                android:layout_marginEnd="5dp"/>

            <Button
                android:id="@+id/btnStats"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/btn_stats"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnStationManager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manager Stații"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8E24AA"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnExport"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/btn_export"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2E7D32"
                android:layout_marginEnd="5dp"/>

            <Button
                android:id="@+id/btnImport"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/btn_import"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C62828"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>